# Genera con: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=<clave-segura-generada>
DEBUG=False

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=ver_y_data
DB_USER=postgres
DB_PASSWORD=<contraseña-segura>
DB_HOST=db
DB_PORT=5432

# MinIO — INTERNO: comunicación API→MinIO dentro de Docker
MINIO_ENDPOINT=minio:9000
MINIO_USE_HTTPS=False
MINIO_CERT_CHECK=False
# MinIO — PÚBLICO: IP del servidor (presigned URLs que abre el navegador)
MINIO_PUBLIC_ENDPOINT=192.64.85.84:9000
MINIO_PUBLIC_USE_HTTPS=False
MINIO_ACCESS_KEY=<access-key>
MINIO_SECRET_KEY=<secret-key-minimo-8-chars>
MINIO_BUCKET=euro-vyd
MINIO_BUCKET_CONTRATOS=euro-contratos

# JWT
ACCESS_TOKEN_LIFETIME=60
REFRESH_TOKEN_LIFETIME=1

# Email
EMAIL_USER=lambda.jhonnatan@gmail.com
EMAIL_PASS=<app-password-gmail>

# Celery + Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# CORS — origen del frontend (IP del servidor)
CORS_ALLOWED_ORIGINS=http://192.64.85.84

# URL base del frontend (para links de firma en emails)
FRONTEND_URL=http://192.64.85.84/ver-y-data

# SIESA (SQL Server)
SIESA_SERVER=190.158.6.93,20446
SIESA_DB=UNOEE
SIESA_UID=consultaeuro
SIESA_PWD=<password-siesa>
