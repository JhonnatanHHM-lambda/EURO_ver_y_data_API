# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=EURO_ver_y_data.settings
DEBUG=True
SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
DB_NAME=ver_y_data
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_HOST=localhost
DB_PORT=5432

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME=60          # minutos
REFRESH_TOKEN_LIFETIME=1          # días

# ── Email (Microsoft Graph API / Office 365) ──────────────────────────────────
# App Registration en Azure AD con permiso Mail.Send (application)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Celery + Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
DB_PASSWORD=tu_password_aqui
# ── CORS ──────────────────────────────────────────────────────────────────────
# En producción reemplaza con el dominio real (sin barra final)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── OptimizacionCorreos — RADIAN ────────────────────────────────────────────
OC_DIAN_NIT=900XXXXXX
OC_DIAN_CC_REP_ENC=<generado por manage.py configurar_secretos>
OC_DIAN_NOMBRE_REP=NombreRepresentante
OC_CAPSOLVER_API_KEY=CAP-XXXXX
OC_CAPSOLVER_SITE_KEY=0x4AAAAAAAg1WuNb-OnOa76z
OC_GRAPH_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OC_GRAPH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
OC_GRAPH_MAILBOX_UPN=buzon@dominio.com
OC_GRAPH_CERT_KEY_PATH=./certs/oc_graph.key.pem
OC_GRAPH_CERT_PUB_PATH=./certs/oc_graph.cer

# ─── OptimizacionCorreos — Zimbra ─────────────────────────────────────────────
OC_ZIMBRA_HOST=mail.eurosupermercados.com
OC_ZIMBRA_EMAIL=facturaelectronica@eurosupermercados.com
OC_ZIMBRA_PASSWORD_ENC=<generado por manage.py configurar_secretos>
OC_ZIMBRA_API_URL=http://localhost:8765

# ─── OptimizacionCorreos — Config ─────────────────────────────────────────────
OC_MASTER_KEY_PATH=./secrets/oc_master.key
