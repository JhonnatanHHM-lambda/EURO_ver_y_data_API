# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=EURO_ver_y_data.settings
DEBUG=True
SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion

# ── Base de datos PostgreSQL ──────────────────────────────────────────────────
DB_NAME=ver_y_data
DB_USER=postgres
DB_PASSWORD=tu_password_aqui
DB_HOST=localhost
DB_PORT=5432

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME=60          # minutos
REFRESH_TOKEN_LIFETIME=1          # días

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Requiere App Password de Google (no la contraseña normal de Gmail)
# Activar en: https://myaccount.google.com/apppasswords
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── Celery + Redis ────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── CORS ──────────────────────────────────────────────────────────────────────
# En producción reemplaza con el dominio real (sin barra final)
CORS_ALLOWED_ORIGINS=http://localhost:5173
